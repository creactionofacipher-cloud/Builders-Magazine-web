# Frontend origin the Presentation tool / "Open Preview" action opens —
# must be SANITY_STUDIO_-prefixed to reach the Studio's Vite bundle.
# Defaults to http://localhost:3000 (the local Next.js dev server) when
# unset, so this only needs to be set to point Studio at a deployed
# frontend.
# SANITY_STUDIO_PREVIEW_URL=

# Shared secret the frontend's /api/draft-mode/enable route checks before
# turning on draft mode — must match SANITY_PREVIEW_SECRET in the main
# app's .env.local exactly.
SANITY_STUDIO_PREVIEW_SECRET=
