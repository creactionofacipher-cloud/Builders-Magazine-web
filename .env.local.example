# Sanity CMS — configured in Milestone 10 (CMS Integration).
# Copy this file to .env.local and fill in values once the Sanity project exists.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=

# Canonical site origin, used for canonical URLs / Open Graph metadata.
# Falls back to http://localhost:3000 in local development if unset.
NEXT_PUBLIC_SITE_URL=

# Shared secret checked by app/api/draft-mode/enable — must match
# SANITY_STUDIO_PREVIEW_SECRET in studio/.env.local exactly. Generate
# with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SANITY_PREVIEW_SECRET=

# Where Sanity Studio is hosted — used to stega-encode draft preview
# content for click-to-edit overlays (@sanity/visual-editing). Falls
# back to http://localhost:3333 (the local Studio dev server) if unset.
SANITY_STUDIO_URL=
